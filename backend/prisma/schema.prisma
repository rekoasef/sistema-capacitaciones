// backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
  // "native" para tu entorno local, "linux-musl..." para Docker/Render.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"] 
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Capacitacion {
  id          Int       @id @default(autoincrement())
  nombre      String    @unique
  descripcion String
  instructor  String
  modalidad   String
  ubicacion   String   
  visible     Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  grupos      Grupo[]
}

// --- MODELO GRUPO (MODIFICADO para Fase 9.0) ---
model Grupo {
  id             Int           @id @default(autoincrement())
  // TAREA 9.1: ELIMINADO: fechaInicio DateTime
  // TAREA 9.1: ELIMINADO: fechaFin DateTime
  cupoMaximo     Int
  capacitacion   Capacitacion  @relation(fields: [capacitacionId], references: [id])
  capacitacionId Int
  inscripciones  Inscripcion[]
  // TAREA 9.1: Nuevo: Relación a Segmentos
  segmentos      GrupoSegmento[] 
}

// --- NUEVO MODELO DE SEGMENTO DE GRUPO (TAREA 9.1) ---
model GrupoSegmento {
  id          Int      @id @default(autoincrement())
  dia         DateTime // Día del segmento
  horaInicio  String   // Hora de inicio (ej: "09:00")
  horaFin     String   // Hora de finalización (ej: "16:00")
  
  grupo       Grupo    @relation(fields: [grupoId], references: [id])
  grupoId     Int
  
  // Restricción: Un grupo solo puede tener un segmento por día
  @@unique([grupoId, dia])
}


model Concesionario {
  id            Int           @id @default(autoincrement())
  nombre        String        @unique
  inscripciones Inscripcion[]
}


// --- MODELO INSCRIPCION (Se mantiene) ---
model Inscripcion {
  id                     Int            @id @default(autoincrement())
  nombreUsuario          String 
  emailUsuario           String
  estado                 String         @default("PENDIENTE")
  grupo                  Grupo          @relation(fields: [grupoId], references: [id])
  grupoId                Int
  createdAt              DateTime       @default(now())

  telefono               String?
  informacionAdicional   String?

  concesionario          Concesionario  @relation(fields: [concesionarioId], references: [id])
  concesionarioId        Int

  @@unique([emailUsuario, grupoId])
}

model Admin {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}