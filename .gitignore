# .gitignore

# --- Secretos y Entorno ---
# Ignorar todos los archivos .env
# .env (local)
# .env.local (usado por Next.js para variables locales)
# .env.production (usado en producción)
# .env.development (usado en desarrollo)
.env
.env.*
!.env.example

# --- Dependencias ---
# Ignorar node_modules en todas las carpetas (root, backend, frontend)
**/node_modules
/node_modules

# --- Logs ---
# Ignorar logs de npm y yarn
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Next.js (Frontend) ---
# Ignorar carpetas de build y caché de Next.js
/frontend/.next
/frontend/out

# --- NestJS (Backend) ---
# Ignorar carpetas de build y caché de NestJS
/backend/dist
/backend/.tmp
/backend/.cache

# --- Docker ---
# Ignorar datos de la base de datos local si se mapea a un volumen
/data/db

# --- Sistema Operativo ---
.DS_Store
Thumbs.db